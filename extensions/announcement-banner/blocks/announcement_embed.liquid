{% comment %}
  Announcement Banner — App Embed Block
  Reads from shop metafield: my_app.announcement
  Displays a sticky top banner on every storefront page.
  Hidden automatically when metafield is empty.
{% endcomment %}

{% assign announcement_text = shop.metafields.my_app.announcement.value %}

{% if announcement_text != blank %}
  <div
    id="announcement-banner"
    class="announcement-banner"
    role="alert"
    aria-live="polite"
    aria-label="Store announcement"
    data-announcement="{{ announcement_text | escape }}"
  >
    <div class="announcement-banner__inner">
      <span class="announcement-banner__icon" aria-hidden="true">📢</span>
      <p class="announcement-banner__text">{{ announcement_text }}</p>
      <button
        class="announcement-banner__close"
        aria-label="Close announcement"
        onclick="closeAnnouncementBanner()"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <style>
    /* ── Announcement Banner Styles ─────────────────────────────── */
    .announcement-banner {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      background-color: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
      font-family: inherit;
      transform: translateY(0);
      opacity: 1;
      transition: transform 0.35s ease, opacity 0.35s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .announcement-banner.is-hidden {
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
    }

    .announcement-banner__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 12px 48px 12px 16px;
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
    }

    .announcement-banner__icon {
      font-size: 1rem;
      flex-shrink: 0;
    }

    .announcement-banner__text {
      margin: 0;
      font-size: {{ block.settings.font_size }}px;
      font-weight: {{ block.settings.font_weight }};
      line-height: 1.5;
      text-align: center;
      flex: 1;
    }

    .announcement-banner__close {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      cursor: pointer;
      color: {{ block.settings.text_color }};
      padding: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      opacity: 0.75;
      transition: opacity 0.2s ease, background-color 0.2s ease;
      line-height: 0;
    }

    .announcement-banner__close:hover {
      opacity: 1;
      background-color: rgba(0, 0, 0, 0.1);
    }

    .announcement-banner__close:focus-visible {
      outline: 2px solid {{ block.settings.text_color }};
      outline-offset: 2px;
    }

    /* ── Responsive ─────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .announcement-banner__inner {
        padding: 10px 44px 10px 12px;
        gap: 8px;
      }

      .announcement-banner__text {
        font-size: {{ block.settings.font_size | minus: 1 }}px;
      }
    }

    @media (max-width: 480px) {
      .announcement-banner__inner {
        padding: 8px 40px 8px 10px;
      }

      .announcement-banner__text {
        font-size: 13px;
      }

      .announcement-banner__icon {
        display: none;
      }
    }

    /* ── Dark mode support ──────────────────────────────────────── */
    @media (prefers-color-scheme: dark) {
      .announcement-banner {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
      }
    }
  </style>

  <script>
    (function () {
      'use strict';

      var DISMISSED_KEY = 'announcement_banner_dismissed';
      var banner = document.getElementById('announcement-banner');

      if (!banner) return;

      // Check if user already dismissed this exact announcement
      var currentText = banner.getAttribute('data-announcement');
      var dismissed = sessionStorage.getItem(DISMISSED_KEY);

      if (dismissed === currentText) {
        banner.style.display = 'none';
        return;
      }

      // Close handler
      window.closeAnnouncementBanner = function () {
        banner.classList.add('is-hidden');
        // After transition completes, hide from DOM flow
        setTimeout(function () {
          banner.style.display = 'none';
        }, 360);
        // Remember dismissal for this session
        sessionStorage.setItem(DISMISSED_KEY, currentText);
      };

      // Keyboard: close on Escape
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          window.closeAnnouncementBanner();
        }
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    }
  ]
}
{% endschema %}
